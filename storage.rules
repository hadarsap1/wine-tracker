rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read/write their own uploads
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Only household members can read/write household uploads
    match /households/{householdId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/households/$(householdId)/members/$(request.auth.uid));
    }
  }
}
