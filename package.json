{
  "name": "wine-tracker",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run --config vitest.rules.config.ts",
    "build:web": "expo export -p web && npm run pwa:inject",
    "pwa:inject": "node scripts/inject-pwa.js && cp -r public/. dist/ && cp assets/icon.png dist/icon.png && cp assets/icon.png dist/icon-maskable.png",
    "deploy": "npm run build:web && firebase deploy --only hosting",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "babel-preset-expo": "~54.0.10",
    "exceljs": "^4.4.0",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@expo/ngrok": "^4.1.3",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "private": true
}
